rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public read for storefront collections
    match /products/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /sessions/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /testimonials/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /banners/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
